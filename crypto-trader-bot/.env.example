# Environment Variables Template
# Copy this file to .env and fill in your values

# Bot Configuration
MODE=paper
LOG_LEVEL=INFO

# Database - PostgreSQL
POSTGRES_USER=crypto_bot
POSTGRES_PASSWORD=changeme_secure_password
POSTGRES_DB=crypto_bot

# Database - Redis
REDIS_PASSWORD=changeme_secure_password

# Database - InfluxDB
INFLUXDB_USER=admin
INFLUXDB_PASSWORD=changeme_secure_password
INFLUXDB_TOKEN=my-super-secret-token-change-me

# Database - MongoDB
MONGO_USER=crypto_bot
MONGO_PASSWORD=changeme_secure_password

# Exchanges - Binance
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Exchanges - Coinbase Pro
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_API_SECRET=your_coinbase_api_secret_here
COINBASE_PASSPHRASE=your_coinbase_passphrase_here

# Exchanges - Kraken
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_API_SECRET=your_kraken_api_secret_here

# Notifications - Email
EMAIL_FROM=bot@example.com
EMAIL_TO=you@example.com
EMAIL_USERNAME=your_smtp_username
EMAIL_PASSWORD=your_smtp_password

# Notifications - Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Notifications - Discord
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Notifications - SMS (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890
TWILIO_TO_NUMBER=+1234567890

# Security
JWT_SECRET_KEY=change-me-to-a-random-secret-key-min-32-chars

# Monitoring - Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
